{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "paths": {
      "@inertia-node/core": ["../packages/core/dist/index.d.ts"],
      "@inertia-node/express": ["../packages/express/dist/index.d.ts"],
      "@inertia-node/nest": ["../packages/nest/dist/index.d.ts"],
      "@inertia-node/nest-fastify": [
        "../packages/nest-fastify/dist/index.d.ts"
      ],
      "@inertia-node/ssr": ["../packages/ssr/dist/index.d.ts"],
      "@inertia-node/create": ["../packages/create/dist/index.d.ts"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
