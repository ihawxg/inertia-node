{
  "name": "@inertia-node/nest",
  "version": "0.1.0",
  "description": "NestJS adapter for Inertia.js on Node.js.",
  "license": "MIT",
  "author": "Inertia Node Adapter contributors",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/inertia-node/inertia-node-adapter.git",
    "directory": "packages/nest"
  },
  "homepage": "https://github.com/inertia-node/inertia-node-adapter#readme",
  "bugs": {
    "url": "https://github.com/inertia-node/inertia-node-adapter/issues"
  },
  "keywords": [
    "inertia",
    "inertiajs",
    "nestjs",
    "node",
    "react",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inertia-node/core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10 <12",
    "@nestjs/core": ">=10 <12",
    "express": ">=4.18 <6",
    "reflect-metadata": ">=0.1 <1",
    "rxjs": ">=7 <8"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/supertest": "^6.0.3",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
