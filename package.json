{
  "name": "inertia-node-adapter",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript Node.js server adapters for Inertia.js.",
  "license": "MIT",
  "author": "Inertia Node Adapter contributors",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/inertia-node/inertia-node-adapter.git"
  },
  "homepage": "https://github.com/inertia-node/inertia-node-adapter#readme",
  "bugs": {
    "url": "https://github.com/inertia-node/inertia-node-adapter/issues"
  },
  "keywords": [
    "inertia",
    "inertiajs",
    "node",
    "express",
    "react",
    "typescript",
    "ssr"
  ],
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "clean": "pnpm -r --filter './packages/**' clean",
    "dev:example": "pnpm --filter @inertia-node/example-express-react dev",
    "dev:example:nest": "pnpm --filter @inertia-node/example-nest-react dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:check": "pnpm build && node scripts/pack-check.mjs",
    "test:dts": "pnpm build && tsc -p test-dts/tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@changesets/cli": "^2.29.7",
    "@inertiajs/react": "3.3.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/testing": "^11.1.9",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.1",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "prettier": "^3.7.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.1.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  }
}
